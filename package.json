{
  "name": "calendar-spartan",
  "version": "0.1.0",
  "description": "An accessible, responsive calendar with day / week / month views, built with Angular 21, spartan-ng and Tailwind 4. Persists events to localStorage and syncs across browser tabs.",
  "keywords": [
    "calendar",
    "angular",
    "spartan-ng",
    "tailwindcss",
    "accessibility",
    "wcag",
    "responsive",
    "playwright",
    "vitest"
  ],
  "license": "MIT",
  "author": "Carlos Benitez <cbenitez.exe@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/carlos11benitez/calendar-spartan.git"
  },
  "homepage": "https://calendar-spartan.netlify.app",
  "bugs": {
    "url": "https://github.com/carlos11benitez/calendar-spartan/issues"
  },
  "private": true,
  "packageManager": "npm@10.9.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 4200",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "screenshots": "SCREENSHOTS=1 playwright test e2e/specs/screenshots.spec.ts"
  },
  "dependencies": {
    "@angular/animations": "^21.2.9",
    "@angular/cdk": "^21.0.0",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@ng-icons/core": "^33.2.2",
    "@ng-icons/lucide": "^33.2.2",
    "@spartan-ng/brain": "0.0.1-alpha.641",
    "@tailwindcss/postcss": "^4.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "ngx-scrollbar": "^19.1.4",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tslib": "^2.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.2",
    "@angular/cli": "^21.1.2",
    "@angular/compiler-cli": "^21.1.0",
    "@playwright/test": "^1.59.1",
    "@spartan-ng/cli": "0.0.1-alpha.641",
    "jsdom": "^27.4.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.1.5"
  }
}
